# ===== NTU EventConnect Backend env =====
# 複製這份成 backend/.env，依照你的環境填值。
# .env 已被 .gitignore 排除，不會 commit 到 repo。

# --- 環境 ---
# dev / prod。prod 時 JWT_SECRET 一定要改。
ENV=dev

# --- 資料庫 ---
# 預設：SQLite（零設定，適合本機開發）
# 如果要切到 PostgreSQL，改成下面這行（記得 pip install -r requirements.txt 把 psycopg 裝進來）：
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
#
# 範例：
#   本機 docker：    postgresql+psycopg://postgres:postgres@localhost:5432/eventconnect
#   組員的遠端：     postgresql+psycopg://app:secret@db.example.com:5432/eventconnect
#   要 SSL：         在最後加 ?sslmode=require

# --- JWT ---
# 開發可以留預設。部署到 prod 前一定要換成隨機長字串：
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- CORS ---
# 前端 dev server 的 origin。Vite 自動跳 port 時記得補上對應的：
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177

# --- Google OAuth（選用） ---
# 沒要用 Google 登入就留空
GOOGLE_CLIENT_ID=
